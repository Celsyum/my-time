<Window x:Class="MyTime.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="MyTime" Height="720" Width="960" MinHeight="600" MinWidth="760">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" LastChildFill="False" Margin="0,0,0,12">
            <Button x:Name="QuitAppButton"
                Content="Quit App"
                Width="110"
                Height="32"
                Margin="0,0,8,0"
                HorizontalAlignment="Right"
                Click="QuitApp_Click"
                DockPanel.Dock="Right" />
            <Button Content="Settings"
                    Width="110"
                    Height="32"
                    HorizontalAlignment="Right"
                    Click="OpenSettings_Click"
                    DockPanel.Dock="Right" />
            <TextBlock Text="MyTime"
                       FontSize="28"
                       FontWeight="Bold"
                       VerticalAlignment="Center" />
        </DockPanel>

        <Border Grid.Row="1" BorderThickness="1" CornerRadius="8" Padding="16" BorderBrush="#DDDDDD" Margin="0,0,0,12">
            <StackPanel>
                <TextBlock Text="Elapsed Time"
                           FontSize="18"
                           FontWeight="SemiBold"
                           Margin="0,0,0,8" />
                <TextBlock x:Name="ElapsedText"
                           Text="00:00:00"
                           FontSize="42"
                           FontWeight="Bold"
                           Margin="0,0,0,4" />
                <TextBlock x:Name="TimerStateText"
                           Text="Idle"
                           FontSize="14"
                           FontWeight="SemiBold"
                           Foreground="#666666"
                           Margin="0,0,0,12" />
                <StackPanel Orientation="Horizontal">
                    <Button x:Name="StartStopButton"
                        Content="Start"
                        Width="140"
                        Height="42"
                        Click="StartStop_Click" />
                    <Button x:Name="PauseResumeButton"
                        Content="Pause"
                        Width="140"
                        Height="42"
                        Margin="8,0,0,0"
                        Click="PauseResume_Click" />
                </StackPanel>

                <StackPanel x:Name="DescriptionPanel" Margin="0,12,0,0" Visibility="Collapsed">
                    <TextBlock Text="Description (required)" FontWeight="SemiBold" />
                    <TextBox x:Name="DescriptionTextBox" Margin="0,6,0,0" Height="70" TextWrapping="Wrap" AcceptsReturn="True" />
                    <DockPanel Margin="0,8,0,0">
                        <TextBlock x:Name="ValidationText" Foreground="#B00020" VerticalAlignment="Center" />
                        <Button Content="Save" Width="100" Height="32" DockPanel.Dock="Right" Click="Save_Click" />
                    </DockPanel>
                </StackPanel>
            </StackPanel>
        </Border>

        <DockPanel Grid.Row="2" LastChildFill="False" Margin="0,0,0,8">
            <TextBlock Text="History" FontSize="20" FontWeight="SemiBold" VerticalAlignment="Center" />
            <ComboBox x:Name="GroupByComboBox"
                      Width="160"
                      Margin="12,0,0,0"
                      SelectionChanged="GroupByComboBox_SelectionChanged"
                      DockPanel.Dock="Right">
                <ComboBoxItem Content="Day" IsSelected="True" />
                <ComboBoxItem Content="Week" />
                <ComboBoxItem Content="Month" />
            </ComboBox>
        </DockPanel>

        <Border Grid.Row="3" BorderThickness="1" CornerRadius="8" Padding="8" BorderBrush="#DDDDDD">
            <ListBox x:Name="HistoryListBox" BorderThickness="0">
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <TextBlock Text="{Binding Text}" TextWrapping="Wrap" Margin="2,2,2,2" />
                    </DataTemplate>
                </ListBox.ItemTemplate>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsHeader}" Value="True">
                                <Setter Property="FontWeight" Value="Bold" />
                                <Setter Property="Background" Value="#F4F4F4" />
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
            </ListBox>
        </Border>

        <Border x:Name="SettingsOverlay"
                Grid.RowSpan="4"
                Background="#CCFFFFFF"
                Visibility="Collapsed">
            <Border Width="420"
                    Padding="18"
                    CornerRadius="8"
                    BorderThickness="1"
                    BorderBrush="#DDDDDD"
                    Background="White"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Center">
                <StackPanel>
                    <TextBlock Text="Settings" FontSize="22" FontWeight="Bold" />
                    <TextBlock Text="Activity retention (months)" Margin="0,16,0,4" FontWeight="SemiBold" />
                    <TextBox x:Name="RetentionMonthsTextBox" Height="30" />
                    <TextBlock x:Name="SettingsValidationText" Margin="0,8,0,0" Foreground="#B00020" />
                    <DockPanel Margin="0,18,0,0" LastChildFill="False">
                        <Button Content="Close" Width="100" Height="32" Click="CloseSettings_Click" />
                        <Button Content="Save Settings" Width="120" Height="32" Margin="8,0,0,0" Click="SaveSettings_Click" />
                    </DockPanel>
                </StackPanel>
            </Border>
        </Border>
    </Grid>
</Window>
